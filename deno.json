{
  "name": "chat-responses-proxy",
  "version": "0.1.0",
  "exports": "./main.ts",
  "tasks": {
    "start": "deno run --allow-net --allow-env --allow-read --allow-write main.ts",
    "dev": "deno run --watch --allow-net --allow-env --allow-read --allow-write main.ts --verbose",
    "test": "deno test --allow-net --allow-env --allow-read --allow-write",
    "check": "deno check main.ts main_test.ts",
    "fmt": "deno fmt"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@1"
  }
}
